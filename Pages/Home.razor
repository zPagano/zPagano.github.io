    <section class="content-section" id="overview">
        <div class="section-header">
            <h3>Overview</h3>
            <div class="accent-line"></div>
        </div>
        <div class="section-body text-block">
            <p>I am a Computer Science student focused on <strong>backend software architecture</strong>. I specialize in designing scalable microservices and event-driven systems using <strong>C#</strong>, <strong>.NET</strong>, and SQL Server.</p>
            <p>Currently, I am engineering a game-agnostic, multi-tenant intelligence platform that leverages the <strong>CQRS</strong> pattern and distributed caching to optimize high-volume data operations. My background includes rigorous data-driven scouting and draft optimization for competitive eSports organizations, where I translated complex telemetry into actionable strategic frameworks.</p>
            <p>I am seeking a Software Engineering position where I can apply my knowledge of distributed caching, asynchronous processing, and backend development to solve complex enterprise challenges.</p>
        </div>
    </section>

    <section class="content-section" id="portfolio">
        <div class="section-header">
            <h3>Engineering Portfolio</h3>
            <div class="accent-line"></div>
        </div>
        <div class="section-body">
            <div class="card project-card">
                <div class="card-header">
                    <h4>Project Vantage</h4>
                    <span class="badge">C# | .NET 10 | CQRS | RabbitMQ | Redis</span>
                </div>
                <div class="card-body">
                    <p>Engineered a game-agnostic, multi-tenant eSports intelligence platform utilizing a microservices architecture, orchestrating backend services with .NET Aspire.</p>
                    <ul>
                        <li>Implemented the Command Query Responsibility Segregation (CQRS) pattern to optimize high-volume data operations, leveraging Entity Framework Core with SQL Server for persistence and Redis for caching.</li>
                        <li>Designed scalable workflows using RabbitMQ to process asynchronous eSports data, researching and integrating concepts from TrueSkill matchmaking algorithms to evaluate player performance metrics.</li>
                    </ul>
                    <a href="https://github.com/zPagano/ProjectVantage" target="_blank" rel="noopener noreferrer" class="text-link">View Source Code &rarr;</a>
                </div>
            </div>
        </div>
    </section>

    <section class="content-section" id="experience">
        <div class="section-header">
            <h3>Experience</h3>
            <div class="accent-line"></div>
        </div>
        <div class="section-body experience-grid">
            <div class="card experience-card">
                <div class="card-header">
                    <h4>Manager & Primary Analyst</h4>
                    <span class="date-range">Apr 2025 – Oct 2025</span>
                </div>
                <div class="card-subheader">
                    <h5>Kevod eSports & Black Bulls | Remote</h5>
                </div>
                <div class="card-body">
                    <ul>
                        <li>Directed data-driven scouting and draft optimization for Tier 3 League of Legends teams using advanced performance metrics.</li>
                        <li>Managed roster development and strategy refinement through rigorous VOD reviews and statistical frameworks.</li>
                    </ul>
                </div>
            </div>

            <div class="card experience-card">
                <div class="card-header">
                    <h4>Collegiate Athlete (Valorant & LoL)</h4>
                    <span class="date-range">Aug 2022 – May 2024</span>
                </div>
                <div class="card-subheader">
                    <h5>Dallas College eSports | Dallas, TX</h5>
                </div>
                <div class="card-body">
                    <ul>
                        <li>Competed at the collegiate level, executing high-pressure macro-strategies and cross-map communication.</li>
                        <li>Maintained rigorous practice and review schedules while concurrently managing a full-time computer science academic workload.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    @if (EventImages != null && EventImages.Any())
    {
        <section class="content-section" id="events">
            <div class="section-header">
                <h3>Events & Footprint</h3>
                <div class="accent-line"></div>
            </div>
            <div class="section-body">
                <div class="gallery-grid">
                    @foreach (var image in EventImages)
                    {
                        <img src="@image" alt="Event Photography" class="brutalist-image" />
                    }
                </div>
            </div>
        </section>
    }

    <footer class="site-footer">
        <p>Lucas Pagano Polisel | C# | .NET | Microservices</p>
    </footer>
</div>

@code {
    private List<string> EventImages = new List<string>();
}