<nav class="sticky-nav">
    <div class="nav-container">
        <div class="nav-brand">
            <a href="#hero" class="brand-link">LPP</a>
        </div>
        <ul class="nav-links">
            <li><a href="#overview">Overview</a></li>
            <li><a href="#portfolio">Portfolio</a></li>
            <li><a href="#experience">Experience</a></li>
            
            @* Uncomment this line when you add images to the EventImages array in Home.razor *@
            @* <li><a href="#events">Events</a></li> *@
            
            <li>
                <button class="theme-toggle" @onclick="InvokeThemeToggle" aria-label="Toggle Dark Mode">
                    @(IsDarkMode ? "[LIGHT]" : "[DARK]")
                </button>
            </li>
        </ul>
    </div>
</nav>

@code {
    [Parameter] public bool IsDarkMode { get; set; }
    [Parameter] public EventCallback OnThemeToggled { get; set; }

    private async Task InvokeThemeToggle()
    {
        await OnThemeToggled.InvokeAsync();
    }
}